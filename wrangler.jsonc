/**
 * Cloudflare Workers configuration for BuilderAgent.io
 *
 * Deploys the built static site (./dist) as a Worker with Static Assets.
 * Run `npx wrangler deploy` to ship — Cloudflare's UI dashboard / Git
 * integration runs this same command on every push.
 *
 * Docs: https://developers.cloudflare.com/workers/static-assets/
 */
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "builderagent-io",
  "compatibility_date": "2025-05-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  }
}
