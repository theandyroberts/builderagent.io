---
const year = new Date().getFullYear();
const cols = [
  {
    title: 'Product',
    links: [
      { href: '/features', label: 'Features' },
      { href: '/pricing', label: 'Pricing' },
      { href: '/use-cases', label: 'Use Cases' },
      { href: '/docs', label: 'Documentation' },
    ],
  },
  {
    title: 'Company',
    links: [
      { href: '/about', label: 'About' },
      { href: '/blog', label: 'Blog' },
      { href: '/contact', label: 'Contact' },
      { href: 'https://instaclaw.bot', label: 'InstaClaw.bot ↗', external: true },
    ],
  },
  {
    title: 'Resources',
    links: [
      { href: '/docs', label: 'Quickstart' },
      { href: '/use-cases', label: 'Examples' },
      { href: '/blog/what-is-an-ai-agent', label: 'What is an AI agent?' },
      { href: '/blog/fly-io-for-ai-agents', label: 'fly.io for AI agents' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { href: '/privacy', label: 'Privacy Policy' },
      { href: '/terms', label: 'Terms of Service' },
    ],
  },
];
---

<footer class="border-t border-[var(--color-line)] bg-[var(--color-surface)] mt-24">
  <div class="container-app py-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-10">
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 text-lg font-semibold tracking-tight" style="font-family: var(--font-display); color: var(--color-ink);">
          <svg width="24" height="24" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <rect x="2" y="2" width="28" height="28" rx="8" fill="var(--color-ink)"/>
            <path d="M10 22 L16 8 L22 22 M12.5 17 L19.5 17" stroke="var(--color-spark)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <circle cx="24" cy="9" r="2" fill="var(--color-brand)"/>
          </svg>
          BuilderAgent
        </a>
        <p class="mt-3 text-sm text-[var(--color-muted)] max-w-xs">
          The fastest way to build, deploy, and run AI agents in the cloud. Powered by OpenClaw.
        </p>
      </div>

      {cols.map((col) => (
        <div>
          <h4 class="text-xs uppercase tracking-wider font-semibold text-[var(--color-ink)]" style="font-family: var(--font-body); letter-spacing: 0.08em;">
            {col.title}
          </h4>
          <ul class="mt-4 space-y-2.5">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)] transition-colors"
                  {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-14 pt-8 border-t border-[var(--color-line)] flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
      <p class="text-xs text-[var(--color-muted)]">
        © {year} BuilderAgent. All rights reserved. A sister product of <a href="https://instaclaw.bot" class="underline hover:text-[var(--color-ink)]">InstaClaw.bot</a>.
      </p>
      <p class="text-xs text-[var(--color-muted)]">
        Made for builders. Powered by <span class="font-medium text-[var(--color-ink-soft)]">OpenClaw</span>, the #1 open-source AI assistant.
      </p>
    </div>
  </div>
</footer>
